{
  "name": "maestrocut",
  "version": "1.0.0",
  "description": "Desktop Non-Linear Video Editor with AI Copilot",
  "main": "electron/main.js",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build --configuration production",
    "build:dev": "ng build --configuration development",
    "watch": "ng build --watch --configuration development",
    "start:electron": "electron .",
    "dev": "concurrently \"ng serve\" \"wait-on http://localhost:4200 && electron .\"",
    "dist": "npm run build && electron-builder",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:win": "npm run build && electron-builder --win",
    "dist:linux": "npm run build && electron-builder --linux",
    "test": "ng test"
  },
  "author": "Hosam Abo Elyazid",
  "license": "MIT",
  "private": true,
  "packageManager": "npm@11.6.2",
  "build": {
    "appId": "com.hosam.maestrocut",
    "productName": "MaestroCut",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/renderer/**/*",
      "electron/**/*.js",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.video",
      "target": ["dmg", "zip"]
    },
    "win": {
      "target": ["nsis", "portable"]
    },
    "linux": {
      "target": ["AppImage", "deb"],
      "category": "Video"
    },
    "extraResources": [
      {
        "from": "assets/",
        "to": "assets/",
        "filter": ["**/*"]
      }
    ]
  },
  "dependencies": {
    "@angular/cdk": "^21.2.6",
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "fluent-ffmpeg": "^2.1.3",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "uuid": "^13.0.0",
    "wavesurfer.js": "^7.12.6"
  },
  "devDependencies": {
    "@angular/build": "^21.2.7",
    "@angular/cli": "^21.2.7",
    "@angular/compiler-cli": "^21.2.0",
    "@google/genai": "^1.49.0",
    "@types/fluent-ffmpeg": "^2.1.28",
    "@types/uuid": "^10.0.0",
    "concurrently": "^9.2.1",
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2",
    "wait-on": "^9.0.5"
  }
}
