# =============================================================================
# Environment Configuration — NLE Video Editor
# =============================================================================
# Copy this file to .env and fill in your values.
# The .env file is loaded by the Electron main process ONLY.
# These values are NEVER sent to the renderer/Angular.
# =============================================================================

# Gemini API Key — get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Gemini Model — which model to use for AI Copilot
GEMINI_MODEL=gemini-2.5-flash

# FFmpeg Binary Path (optional — leave empty to use system PATH)
# FFMPEG_PATH=/usr/local/bin/ffmpeg
# FFPROBE_PATH=/usr/local/bin/ffprobe

# Auto-save interval in milliseconds (default: 60000 = 1 minute)
AUTOSAVE_INTERVAL=60000
